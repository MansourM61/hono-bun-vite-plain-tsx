{
    "name": "hono-bun-plain-tsx",
    "description": "Simple backend server with full support for TypeScript, and TSX",
    "version": "00.00.00",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "bun run --hot src/index.ts",
        "convert": "bun run clean && tsc --build",
        "build": "bun run clean && bun build --minify ./src/index.ts --outdir ./dist --target bun",
        "compile": "bun build src/index.ts --compile --outfile ./dist/index",
        "preview": "cross-env NODE_ENV=production bun dist/index.js",
        "exec": "./dist/index",
        "test": "vitest",
        "check-types": "tsc --noEmit",
        "prepare": "husky",
        "format": "bunx --bun @biomejs/biome format --write .",
        "clean": "rimraf ./dist",
        "doc": "bunx @rcmade/hono-docs generate --config ./hono.docs.ts",
        "lint": "bunx --bun @biomejs/biome check --write"
    },
    "dependencies": {
        "@hono/node-server": "^1.19.11",
        "@hono/standard-validator": "^0.2.2",
        "hono": "^4.12.8",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@hono/swagger-ui": "^0.6.1",
        "@rcmade/hono-docs": "^1.0.32",
        "@repo/biome-config": "workspace:^",
        "@repo/typescript-config": "workspace:*",
        "@scalar/hono-api-reference": "^0.10.4",
        "@types/bun": "latest",
        "cross-env": "^10.1.0",
        "dotenv": "^17.3.1",
        "rimraf": "^6.1.3",
        "typescript": "^6.0.2",
        "vitest": "^4.1.0"
    },
    "openapi": "./openapi/openapi.json",
    "main": "dist/index.cjs",
    "module": "dist/index.js",
    "types": "dist/index.d.cts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            }
        }
    },
    "files": ["dist"],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/MansourM61/hono-bun-plain-tsx.git"
    },
    "packageManager": "bun@1.3.6"
}
