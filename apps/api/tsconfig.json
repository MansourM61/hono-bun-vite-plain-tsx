{
    "extends": "./node_modules/@repo/typescript-config/hono-server.json",
    "compilerOptions": {
        /* project directories */
        "rootDir": "./",
        "outDir": "./dist",
        /* path definitions */
        "paths": {
            "@/*": ["./*"],
            "@src/*": ["./src/*"],
            "@lib/*": ["./src/lib/*"],
            "@middleware/*": ["./src/middleware/*"],
            "@routes/*": ["./src/routes/*"]
        }
    },
    /** source files */
    "files": ["./src/index.ts", "./hono.docs.ts"],
    "include": ["**/*.ts", "**/*.tsx"],
    "exclude": ["src/**/*.test.*", "test/", "dist/"]
}
