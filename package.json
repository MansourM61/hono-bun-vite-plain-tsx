{
	"name": "hono-bun-vite-plain-tsx",
	"version": "0.0.0",
	"description": "Hono-based backend with support of TSX; Vite-based frontend development",
	"license": "MIT",
	"author": "Mojtaba Mansour Abadi",
	"type": "module",
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"lint": "turbo run lint",
		"format": "bunx --bun @biomejs/biome format --write",
		"check-types": "turbo run check-types",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.8",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"turbo": "^2.8.20",
		"typescript": "^6.0.2"
	},
	"packageManager": "bun@1.3.6",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/MansourM61/hono-bun-vite-plain-tsx.git"
	},
	"lint-staged": {
		"**/*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": "biome check --write --no-errors-on-unmatched"
	},
	"workspaces": [
		"apps/*",
		"packages/*"
	]
}
